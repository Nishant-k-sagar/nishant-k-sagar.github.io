---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const socialLinks = [
  {
    name: 'GitHub',
    url: 'https://github.com/nishant-k-sagar',
    description: 'Open source projects and code',
    icon: 'github'
  },
  {
    name: 'LinkedIn',
    url: 'https://linkedin.com/in/nishant-k-sagar',
    description: 'Professional profile and network',
    icon: 'linkedin'
  },
  {
    name: 'Email',
    url: 'https://mail.google.com/mail/?view=cm&fs=1&to=nishantsagar004@gmail.com&su=Reaching%20out%20from%20portfolio',
    description: 'Mail to: nishantsagar004@gmail.com or click it',
    icon: 'email'
  },
  {
    name: 'Old Portfolio',
    url: 'https://nishantksagar.netlify.app/',
    description: 'Link to my old portfolio',
    icon: 'globe'
  }
];
---

<BaseLayout title="Nishant Kumar Sagar | Socials">
  <Header />
  <main class="flex-1">
      <section class="py-4 sm:py-6 px-3 sm:px-6 lg:px-8">
        <div class="max-w-5xl mx-auto">
        <h1 class="text-sm sm:text-base lg:text-lg font-bold font-sans text-green-600 underline decoration-green-600 mb-4 sm:mb-6">
          Socials
        </h1>
        
        <p class="text-sm sm:text-base text-text-2 mb-6 sm:mb-8 max-w-xl">
          Find me on these platforms. I'm most responsive on email.
        </p>

        <div class="space-y-3 sm:space-y-4">
        {socialLinks.map((link) => (
          <a
            href={link.url}
            target={link.url.startsWith('mailto:') ? undefined : '_blank'}
            rel="noopener noreferrer"
            class="block group p-3 sm:p-5 border border-border dark:border-dark-border rounded-lg bg-white dark:bg-surface hover:bg-gray-50 dark:hover:bg-surface-dark transition-colors"
          >
            <div class="flex items-center gap-3 sm:gap-4">
              <div class="text-text shrink-0 w-8 h-8 sm:w-10 sm:h-10 flex items-center justify-center">
                {link.icon === 'github' &&
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" class="sm:w-6 sm:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                }
                {link.icon === 'linkedin' &&
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" class="sm:w-6 sm:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
                }
                {link.icon === 'globe' &&
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" class="sm:w-6 sm:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" x2="22" y1="12" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                }
                {link.icon === 'email' &&
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" class="sm:w-6 sm:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                }
              </div>
                <div class="flex-1 min-w-0">
                  <div class="font-medium text-text group-hover:text-accent transition-colors text-sm sm:text-base">
                    {link.name}
                  </div>
                  <div class="text-xs sm:text-sm text-text-2 truncate">
                    {link.description}
                  </div>
                </div>
                <div class="text-text-2 group-hover:text-text transition-colors shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" class="sm:w-5 sm:h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 17L17 7"/>
                  <path d="M7 7h10v10"/>
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>