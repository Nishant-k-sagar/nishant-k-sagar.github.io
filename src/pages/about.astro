---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-8">About</h1>
    
    <div class="prose prose-sm sm:prose-base">
      <p>Welcome to my personal website. I am a software developer.</p>
      
      <p>Here you will find my projects, blog posts, and what I'm currently working on.</p>
      
      <h2>Skills</h2>
      <ul>
        <li>Web Development</li>
        <li>Software Architecture</li>
        <li>Technical Writing</li>
      </ul>
    </div>
  </div>
</BaseLayout>