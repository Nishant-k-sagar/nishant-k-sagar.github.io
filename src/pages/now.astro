---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection, render } from 'astro:content';

const pages = await getCollection('pages');
const nowPage = pages.find(page => page.data.status === 'published');

if (!nowPage) {
  throw new Error('Now page not found');
}

const { Content } = await render(nowPage);
---

<BaseLayout title={nowPage.data.title}>
  <Header />

  <main class="flex-1">
    <article class="py-4 px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto">
        <header class="mb-4">
          <h1 class="text-3xl font-bold font-serif text-primary">{nowPage.data.title}</h1>
        </header>

        <div class="prose prose-sm sm:prose-base prose-gray dark:prose-invert prose-headings:font-serif prose-headings:font-semibold prose-a:text-accent hover:prose-a:underline prose-blockquote:border-l-4 prose-blockquote:border-accent prose-blockquote:pl-4 prose-blockquote:italic prose-code:bg-paper-dark dark:prose-code:bg-gray-800 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-pre:bg-paper-dark dark:prose-pre:bg-gray-800 prose-pre:text-primary max-w-none">
          <Content />
        </div>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>