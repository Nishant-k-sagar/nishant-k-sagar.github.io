---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'My personal portfolio' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
    <title>{title}</title>
    <script is:inline>
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark')
      } else {
        document.documentElement.classList.remove('dark')
      }
    </script>
  </head>
  <body class="bg-bg text-text font-sans min-h-screen flex flex-col">
    <slot />
  </body>
</html>

<style is:global>
  :root {
    /* Backgrounds */
    --color-bg: #ecfdf5;
    --color-bg-2: #f5f5f4;
    --color-bg-3: #e7e5e4;
    --color-surface: #ffffff;

    /* Borders */
    --color-border: #d6d3d1;
    --color-border-2: #a8a29e;

    /* Text */
    --color-text: #1c1917;
    --color-text-2: #57534e;
    --color-text-3: #a8a29e;

    /* Accent */
    --color-accent: #0d9488;
    --color-accent-bg: #f0fdfa;
    --color-accent-text: #0f766e;

    /* Fonts */
    --font-serif: 'Lora', 'Georgia', 'Cambria', 'Times New Roman', serif;
    --font-sans: 'Inter', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', 'Fira Code', 'Courier New', monospace;

    /* Spacing */
    --space-1: 0.25rem;
    --space-2: 0.5rem;
    --space-3: 0.75rem;
    --space-4: 1rem;
    --space-5: 1.25rem;
    --space-6: 1.5rem;
    --space-8: 2rem;
    --space-10: 2.5rem;
    --space-12: 3rem;
    --space-16: 4rem;
    --space-20: 5rem;

    /* Border radius */
    --radius-sm: 4px;
    --radius-md: 8px;
    --radius-lg: 12px;
    --radius-pill: 9999px;

    /* Layout */
    --max-layout: 1100px;
    --max-prose: 640px;
    --max-toc: 220px;
  }

  .dark {
    --color-bg: #111713;
    --color-bg-2: #1a1a1d;
    --color-bg-3: #27272b;
    --color-surface: #1a1a1d;

    --color-border: #27272b;
    --color-border-2: #3a3a3f;

    --color-text: #f8f8f8;
    --color-text-2: #b8b8bc;
    --color-text-3: #88888f;

    --color-accent: #6ee7b7;
    --color-accent-bg: #064e3b;
    --color-accent-text: #34d399;
  }

  * {
    box-sizing: border-box;
  }
  html {
    scroll-behavior: smooth;
    hyphens: auto;
    overflow-wrap: break-word;
    word-wrap: break-word;
    -webkit-hyphens: auto;
    -moz-hyphens: auto;
  }
  body {
    font-family: var(--font-serif);
    text-wrap: pretty;
  }
  p, li, blockquote {
    max-width: 65ch;
    text-wrap: pretty;
    overflow-wrap: break-word;
    word-break: break-word;
    hyphens: auto;
    line-break: strict;
    font-size: clamp(0.875rem, 2vw, 1.0625rem);
    line-height: 1.7;
  }
  h1, h2, h3, h4, h5, h6 {
    text-wrap: balance;
    overflow-wrap: break-word;
    hyphens: none;
  }
  pre code {
    text-wrap: nowrap;
    overflow-x: auto;
    hyphens: none;
  }
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-sans);
  }
  button, input, select, textarea {
    font-family: var(--font-sans);
  }
  a {
    transition: color 0.2s ease;
  }
</style>